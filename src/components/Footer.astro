---
import { site } from '../data/site';
const base = import.meta.env.BASE_URL;
---
<footer>
  <div class="container footer-grid">
    <div>
      <p class="name">{site.name}</p>
      <p>{site.tagline}</p>
    </div>
    <div class="links">
      <a href={`${base}about/`}>關於我</a>
      <a href={`${base}contact/`}>聯絡</a>
      <a href={site.social.facebook} target="_blank" rel="noreferrer">Facebook</a>
      <a href={site.social.instagram}>Instagram</a>
      <a href={site.social.line}>LINE</a>
    </div>
  </div>
  <div class="container copyright">© {new Date().getFullYear()} 小德老師知識中心．內容僅供知識分享，個別案件請洽專業人士。</div>
</footer>
<style>
  footer { padding: 55px 0 28px; color: rgba(255,255,255,.72); background: var(--navy-deep); }
  .footer-grid { display: grid; grid-template-columns: 1fr auto; gap: 40px; }
  .name { margin: 0; color: white; font-size: 1.35rem; font-weight: 800; }
  .footer-grid p:last-child { max-width: 530px; }
  .links { display: flex; flex-wrap: wrap; gap: 24px; align-content: center; }
  .copyright { margin-top: 35px; padding-top: 22px; border-top: 1px solid rgba(255,255,255,.12); font-size: .78rem; }
  @media (max-width: 680px) { .footer-grid { grid-template-columns: 1fr; } }
</style>
