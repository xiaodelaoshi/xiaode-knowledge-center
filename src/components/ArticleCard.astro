---
import { categoryByName } from '../data/site';
const { article } = Astro.props;
const category = categoryByName(article.data.category);
const base = import.meta.env.BASE_URL;
---
<article class="card">
  <a href={`${base}articles/${article.id}/`} aria-label={article.data.title}>
    <div class="top">
      <span>{category?.icon ?? '知'}</span>
      <small>{article.data.category}</small>
    </div>
    <h3>{article.data.title}</h3>
    <p>{article.data.description}</p>
    <div class="meta">
      <time datetime={article.data.publishedAt.toISOString()}>{article.data.publishedAt.toLocaleDateString('zh-TW')}</time>
      <span>閱讀文章 →</span>
    </div>
  </a>
</article>
<style>
  .card { min-width: 0; border: 1px solid var(--line); background: var(--paper); border-radius: var(--radius); transition: .22s ease; overflow: hidden; }
  .card:hover { transform: translateY(-5px); border-color: rgba(199,150,66,.45); box-shadow: var(--shadow); }
  .card a { display: flex; min-height: 300px; padding: 26px; flex-direction: column; }
  .top { display: flex; align-items: center; gap: 10px; }
  .top span { display: grid; place-items: center; width: 38px; height: 38px; color: var(--navy); background: var(--gold-soft); border-radius: 12px; font-weight: 900; }
  small { color: var(--gold); font-weight: 800; }
  h3 { margin: 25px 0 10px; font-size: 1.35rem; }
  p { margin: 0; color: var(--muted); }
  .meta { display: flex; justify-content: space-between; gap: 15px; margin-top: auto; padding-top: 24px; color: var(--muted); font-size: .78rem; }
  .meta span { color: var(--navy); font-weight: 800; }
</style>
