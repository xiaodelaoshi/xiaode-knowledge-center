---
import '../styles/global.css';
import { site } from '../data/site';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}
const { title, description = site.description, image } = Astro.props;
const pageTitle = title ? `${title}｜${site.name}` : site.name;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {image && <meta property="og:image" content={new URL(image, Astro.site)} />}
    <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <aside class="contact-dock" aria-label="快速聯絡小德老師">
      <a class="message" href="https://m.me/zhuang.xiao.de.463208" target="_blank" rel="noreferrer" aria-label="使用 Messenger 私訊小德老師"><span>訊</span><b>私訊小德老師</b></a>
      <a class="facebook" href={site.social.facebook} target="_blank" rel="noreferrer" aria-label="前往小德老師 Facebook"><span>f</span><b>追蹤 Facebook</b></a>
    </aside>
    <Footer />
  </body>
</html>

<style>
  .contact-dock { position: fixed; z-index: 50; right: 18px; bottom: 22px; display: grid; gap: 9px; }
  .contact-dock a { display: flex; align-items: center; gap: 9px; min-height: 48px; padding: 8px 15px 8px 8px; color: white; border: 1px solid rgba(255,255,255,.18); border-radius: 999px; box-shadow: 0 10px 28px rgba(0,0,0,.23); transition: .2s ease; }
  .contact-dock a:hover { transform: translateY(-3px); }
  .contact-dock .message { background: linear-gradient(135deg,#0877ff,#8b4df6); }
  .contact-dock .facebook { background: #172d40; }
  .contact-dock span { display: grid; width: 32px; height: 32px; place-items: center; color: #172d40; background: #efc85b; border-radius: 50%; font-weight: 900; }
  .contact-dock b { font-size: .78rem; }
  @media(max-width:600px) { .contact-dock { right: 12px; bottom: 12px; grid-auto-flow: column; } .contact-dock a { padding-right: 8px; } .contact-dock b { display: none; } }
</style>
