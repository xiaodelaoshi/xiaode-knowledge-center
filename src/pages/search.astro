---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchHero from '../components/SearchHero.astro';
---
<BaseLayout title="搜尋知識中心">
  <header class="search-head"><div class="container"><p class="eyebrow">SEARCH THE KNOWLEDGE</p><h1>今天想了解什麼？</h1><SearchHero compact /></div></header>
  <section class="section"><div class="container results"><p id="status">輸入關鍵字，搜尋小德老師的文章。</p><div id="results"></div></div></section>
  <script define:vars={{ base: import.meta.env.BASE_URL }}>
    const input = document.querySelector('#q');
    const results = document.querySelector('#results');
    const status = document.querySelector('#status');
    const params = new URLSearchParams(location.search);
    const initial = params.get('q') || '';
    input.value = initial;

    async function runSearch(query) {
      if (!query.trim()) return;
      status.textContent = '正在整理相關內容…';
      try {
        const pagefind = await import(`${base}pagefind/pagefind.js`);
        await pagefind.init();
        const search = await pagefind.search(query);
        const items = await Promise.all(search.results.slice(0, 12).map((result) => result.data()));
        status.textContent = items.length ? `找到 ${items.length} 筆相關內容` : '沒有找到完全相符的文章，換個關鍵字試試看。';
        results.innerHTML = items.map((item) => `
          <a class="result" href="${item.url}">
            <small>${item.meta?.title ? '知識文章' : '搜尋結果'}</small>
            <h2>${item.meta?.title || item.url}</h2>
            <p>${item.excerpt || ''}</p>
            <b>閱讀全文 →</b>
          </a>`).join('');
      } catch (error) {
        status.textContent = '搜尋索引會在正式建置後啟用；目前可先瀏覽所有文章。';
      }
    }
    if (initial) runSearch(initial);
  </script>
</BaseLayout>
<style is:global>
  .search-head{padding:90px 0 65px;text-align:center;background:linear-gradient(145deg,#f0eadf,#fff)}.search-head h1{font-size:clamp(2.4rem,5vw,4rem)}.results{max-width:880px}.results>#status{color:var(--muted)}#results{display:grid;gap:14px;margin-top:22px}.result{display:block;padding:25px;border:1px solid var(--line);background:white;border-radius:18px}.result:hover{border-color:var(--gold);box-shadow:var(--shadow)}.result small{color:var(--gold);font-weight:800}.result h2{margin:8px 0;font-size:1.3rem}.result p{color:var(--muted)}.result b{color:var(--navy);font-size:.85rem}
</style>
