---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categoryByName } from '../../data/site';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({ params: { id: article.id }, props: { article } }));
}
const { article } = Astro.props;
const { Content } = await render(article);
const category = categoryByName(article.data.category);
const base = import.meta.env.BASE_URL;
---
<BaseLayout title={article.data.title} description={article.data.description}>
  <article data-pagefind-body>
    <header class="article-head">
      <div class="container narrow">
        <a class="crumb" href={`${base}categories/${category?.slug}/`}>{article.data.category}</a>
        <h1 data-pagefind-meta="title">{article.data.title}</h1>
        <p class="summary">{article.data.description}</p>
        <div class="details">
          <time datetime={article.data.publishedAt.toISOString()}>發布於 {article.data.publishedAt.toLocaleDateString('zh-TW')}</time>
          <span>小德老師</span>
        </div>
      </div>
    </header>
    <div class="section">
      <div class="prose"><Content /></div>
      <div class="article-bottom">
        <div class="tags">
          {article.data.tags.map((tag) => <a href={`${base}tags/${encodeURIComponent(tag)}/`}>#{tag}</a>)}
        </div>
        <div class="share">
          <strong>覺得有幫助嗎？</strong>
          <div class="actions">
            <a class="button primary" href="https://m.me/zhuang.xiao.de.463208" target="_blank" rel="noreferrer">私訊小德老師</a>
            {article.data.facebookUrl && (
              <a class="button" href={article.data.facebookUrl} target="_blank" rel="noreferrer">查看 Facebook 原文</a>
            )}
          </div>
        </div>
        <section class="comments" aria-labelledby="comment-title">
          <div class="comment-head"><div><small>DISCUSSION</small><h2 id="comment-title">留下你的想法</h2></div><p>使用 Facebook 帳號留言，也可以直接私訊小德老師。</p></div>
          <div id="fb-root"></div>
          <div class="fb-comments" data-href={Astro.url.href} data-width="100%" data-numposts="8" data-order-by="reverse_time"></div>
        </section>
      </div>
    </div>
  </article>
  <script is:inline async defer crossorigin="anonymous" src="https://connect.facebook.net/zh_TW/sdk.js#xfbml=1&version=v23.0"></script>
</BaseLayout>
<style>
  .article-head { padding: 90px 0 65px; text-align: center; background: linear-gradient(145deg,#f0eadf,#fff); }
  .narrow { max-width: 900px; }
  .crumb { color: var(--gold); font-size: .85rem; font-weight: 800; }
  .article-head h1 { max-width: 900px; margin: 18px auto; font-size: clamp(2.15rem,5vw,4.1rem); }
  .summary { max-width: 700px; margin: 0 auto; color: var(--muted); font-size: 1.08rem; }
  .details { display: flex; justify-content: center; gap: 22px; margin-top: 25px; color: var(--muted); font-size: .8rem; }
  .article-bottom { max-width: 760px; margin: 60px auto 0; padding-top: 28px; border-top: 1px solid var(--line); }
  .tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .tags a { padding: 6px 12px; color: var(--navy); background: var(--gold-soft); border-radius: 999px; font-size: .78rem; }
  .share { display: flex; justify-content: space-between; align-items: center; gap: 18px; margin-top: 30px; padding: 24px; background: white; border-radius: 18px; box-shadow: var(--shadow); }
  .actions { display: flex; flex-wrap: wrap; gap: 9px; }
  .comments { margin-top: 32px; padding: 28px; border: 1px solid var(--line); background: white; border-radius: 20px; box-shadow: var(--shadow); }
  .comment-head { display: flex; justify-content: space-between; gap: 24px; margin-bottom: 18px; border-bottom: 1px solid var(--line); }
  .comment-head small { color: var(--gold); font-weight: 900; letter-spacing: .14em; }
  .comment-head h2 { margin: 6px 0 18px; font-size: 1.45rem; }
  .comment-head p { max-width: 330px; margin: 5px 0 18px; color: var(--muted); font-size: .85rem; }
  .fb-comments, .fb-comments span, .fb-comments iframe { width: 100% !important; }
  @media(max-width:600px){.share,.comment-head{align-items:flex-start;flex-direction:column}.comments{padding:18px}}
</style>
